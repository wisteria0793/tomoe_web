# Django 設定
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=hakodate-tomoe.com www.hakodate-tomoe.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://hakodate-tomoe.com
DJANGO_SECURE_SSL_REDIRECT=True

# データベース設定 (PostgreSQL)
POSTGRES_DB=tomoe_db
POSTGRES_USER=tomoe_user
POSTGRES_PASSWORD=secure-password-here
# DATABASE_URL は docker-compose 内で上記変数から組み立てられます
